DATABASE_URL=${{ MySQL.MYSQL_URL }}

# Alternatively, if not using a URL:
DB_HOST=127.0.0.1
DB_USER=root
DB_PASSWORD=your_mysql_password
DB_NAME=mindmate
PORT=5002
OPENAI_API_KEY=your_openai_api_key

# Firebase Admin SDK (get from Firebase Console → Project Settings → Service Accounts)
FIREBASE_PROJECT_ID=mindmate-13f29
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@mindmate-13f29.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END RSA PRIVATE KEY-----\n"

# JWT Secret (change this to a strong random string in production)
JWT_SECRET=mindmate-jwt-secret-change-in-production

# MindMateAI - Environment Variables Template

# ---------------------------------------------------------
# Frontend Environment Variables (Vercel)
# ---------------------------------------------------------
VITE_API_URL=https://<your-railway-app-url>.up.railway.app
VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=your_firebase_auth_domain
VITE_FIREBASE_PROJECT_ID=your_firebase_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_firebase_storage_bucket
VITE_FIREBASE_MESSAGING_SENDER_ID=your_firebase_messaging_sender_id
VITE_FIREBASE_APP_ID=your_firebase_app_id
VITE_SENTRY_DSN=your_sentry_dsn_for_react

# ---------------------------------------------------------
# Backend Environment Variables (Railway)
# ---------------------------------------------------------
PORT=3000
NODE_ENV=production

# Database (MySQL via PlanetScale or Railway)
DATABASE_URL=mysql://user:password@host:port/database

# Firebase Admin SDK (Service Account JSON string or individual vars)
# Option 1: Base64 encoded JSON string of the service account
FIREBASE_SERVICE_ACCOUNT_BASE64=your_base64_encoded_service_account
# Option 2: Individual variables
FIREBASE_PROJECT_ID=your_firebase_project_id
FIREBASE_CLIENT_EMAIL=your_firebase_client_email
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# AI Provider Configuration
GROQ_API_KEY=your_groq_api_key

# Frontend URL (for CORS whitelist)
FRONTEND_URL=https://your-vercel-app-url.vercel.app

# Sentry
SENTRY_DSN=your_sentry_dsn_for_node
